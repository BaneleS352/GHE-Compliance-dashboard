# ── Database ──────────────────────────────────────
# PostgreSQL (production / local via Docker):
#   docker compose up -d
#   npx prisma migrate dev --name init
#   npm run db:seed
# DATABASE_URL="postgresql://ghe_user:ghe_password@localhost:5432/ghe_compliance?schema=public"

# SQLite (local dev — no external deps required):
DATABASE_URL="file:./dev.db"

# ── Auth ──────────────────────────────────────────
JWT_SECRET="ghe-jwt-secret-$(uuidgen)-do-not-commit"
PORT=3001
